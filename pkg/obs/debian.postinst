#!/bin/sh
set -e

if [ "$1" = "configure" ]; then
    . /usr/share/laren/postinstall-common.sh
    configure_all_users

    # DEB-specific: set Fcitx5 as input method framework
    if command -v im-config >/dev/null 2>&1; then
        im-config -n fcitx5 2>/dev/null || true
    fi

    echo ""
    echo "  Laren installed successfully!"
    echo "  Log out and back in, then press Ctrl+Space to switch to Laren."
    echo "  To configure: fcitx5-configtool"
    echo ""
fi

#DEBHELPER#
